# Telegram Bot Token (wajib)
BOT_TOKEN=your_bot_token_here

# Database path
DB_PATH=/app/data/messages.db

# Mode: true untuk webhook (production), false untuk polling (development)
USE_WEBHOOK=true

# Webhook URL (wajib jika USE_WEBHOOK=true)
# Format: https://your-app-name.railway.app
WEBHOOK_URL=https://your-app-name.railway.app

# Port untuk webhook (default: 8080)
PORT=8080

# Admin ID untuk notifikasi error (opsional)
ADMIN_ID=your_telegram_id

# Webhook secret (opsional)
WEBHOOK_SECRET=your_secret_here
